# Normalize line endings for a cleaner cross-platform repo.
* text=auto

# Source/config files should remain LF.
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
requirements*.txt text eol=lf

# Windows helper scripts use CRLF.
*.ps1 text eol=crlf

# Binary/image/archive files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
