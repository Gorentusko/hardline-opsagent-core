OPSAGENT_APP_NAME=Hardline OpsAgent Core
OPSAGENT_ENV=demo
OPSAGENT_BIND_HOST=0.0.0.0
OPSAGENT_BIND_PORT=8088

# mock = no external API calls, no cost
# openrouter = user supplies their own OpenRouter key
OPSAGENT_LLM_PROVIDER=mock

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

OPSAGENT_MAX_LLM_CALLS_PER_RUN=1
OPSAGENT_MAX_INPUT_CHARS=12000
OPSAGENT_LLM_TIMEOUT_SECONDS=45

OPSAGENT_REPORT_DIR=/app/data/reports
OPSAGENT_STATE_DIR=/app/data/state
